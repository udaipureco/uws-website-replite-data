@import url('../shared-base.css');
:root { --purple: #5f259f; }
.card { background: #fff; padding: 1.25rem; border-radius: var(--radius-xl); box-shadow: var(--shadow-md); text-align: center; margin: 0.875rem auto; max-width: 600px; width: calc(100% - 2rem); }
.card h3 { margin-bottom: 0.875rem; }
.amount-box { background: #f3e8ff; padding: 0.875rem; border-radius: var(--radius-md); margin-bottom: 0.875rem; }
.amount-box span { font-size: 0.8125rem; color: #555; }
.amount-box h1 { margin: 0.3125rem 0 0; color: var(--purple); }
.upi-box { background: #fafafa; padding: 0.75rem; border-radius: var(--radius-sm); margin-bottom: 0.875rem; }
.upi-box p { margin: 0; font-size: 0.75rem; color: var(--text-light); }
.upi-box strong { font-size: 1rem; }
.qr-box { margin: 0.875rem 0; }
.qr-box img { width: 140px; border-radius: var(--radius-sm); margin: 0 auto; }
.qr-box p { font-size: 0.75rem; color: var(--text-light); }
button { width: 100%; padding: 0.875rem; border: none; border-radius: var(--radius-md); background: var(--purple); color: #fff; font-size: 1rem; font-weight: 700; cursor: pointer; transition: opacity var(--transition); }
button:hover { opacity: 0.9; }
.loading { margin-top: 0.875rem; display: none; color: var(--purple); font-weight: 700; text-align: center; }
@media (min-width: 1025px) { .card { max-width: 500px; } }
