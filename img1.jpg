@import url('../shared-base.css');
body { background: linear-gradient(135deg, #efe6d6, #e4dcc8); }
.container { max-width: 600px; margin: 0 auto; padding: 1.125rem; padding-bottom: 5.5rem; }
.success-title { color: var(--green); font-weight: 800; font-size: 1.5rem; letter-spacing: 0.3px; }
.subtitle { color: var(--text-light); margin-bottom: 1.25rem; font-size: 0.875rem; }
.ticket { position: relative; background: rgba(255,255,255,0.95); backdrop-filter: blur(6px); border-radius: var(--radius-lg); padding: 1.25rem; box-shadow: var(--shadow-lg); overflow: hidden; border: 1px solid rgba(0,0,0,0.04); max-width: 420px; margin: 0 auto; }
.ticket::before { content: ""; position: absolute; top: 50%; left: 50%; width: 300px; height: 300px; background: url('../../images/logo.png') no-repeat center; background-size: contain; transform: translate(-50%,-50%); opacity: 0.04; z-index: 0; }
.ticket > * { position: relative; z-index: 1; }
.ticket h2 { color: var(--green); font-weight: 900; letter-spacing: 0.5px; font-size: 1.125rem; }
.ticket-type { font-weight: 700; color: #222; font-size: 0.8125rem; margin-bottom: 0.3125rem; }
.ticket p { font-size: 0.9375rem; color: #111; margin: 0.375rem 0; }
.total { font-weight: 900; font-size: 1.125rem; }
hr { border: none; border-top: 1px dashed #cfcfcf; margin: 0.75rem 0; }
.title-row { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.3125rem; }
#qrcode { display: flex; justify-content: center; margin: 0.875rem 0; padding: 0.625rem; background: #fff; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); width: fit-content; margin-left: auto; margin-right: auto; }
.rules { text-align: left; font-size: 0.8125rem; color: #444; line-height: 1.6; }
.footer { font-size: 0.75rem; color: #777; margin-top: 0.3125rem; }
.btn-group { position: fixed; bottom: 0; left: 0; width: 100%; display: flex; gap: 0.625rem; padding: 0.75rem 1rem; background: var(--bg); z-index: 100; max-width: 100%; }
.btn-group button { min-width: 0; }
.logo-small { width: 2.5rem; height: 2.5rem; object-fit: contain; flex-shrink: 0; }
body::after { content: ""; position: fixed; top: 50%; left: 50%; width: 500px; height: 500px; background: url('../../images/logo.png') no-repeat center; background-size: contain; transform: translate(-50%,-50%); opacity: 0.03; z-index: 0; pointer-events: none; }
@media (min-width: 481px) { .success-title { font-size: 1.625rem; } .ticket { padding: 1.5rem; } }
@media (min-width: 1025px) { .btn-group { max-width: 650px; left: 50%; transform: translateX(-50%); } }
