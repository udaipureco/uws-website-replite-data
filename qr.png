@import url('../shared-base.css');
.card { background: #fff; padding: 1.125rem; padding-bottom: 1.5rem; }
.main-title { text-align: center; color: var(--green); font-size: 1.25rem; font-weight: 900; margin-bottom: 0.25rem; display: flex; justify-content: center; align-items: center; gap: 0.5rem; }
.subtitle { text-align: center; font-size: 1rem; color: var(--text-light); margin-bottom: 1rem; font-weight: 600; }
.section { margin-bottom: 0.875rem; }
.section h3 { font-size: 0.9375rem; color: var(--green); margin-bottom: 0.5rem; font-weight: 800; }
.section p { margin: 0.25rem 0; font-size: 0.875rem; color: #333; }
#ticketDetails div { display: flex; justify-content: space-between; padding: 0.625rem; margin-top: 0.375rem; background: #fff; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); }
.total-box { background: #f5f5f5; border-radius: var(--radius-md); padding: 0.875rem; text-align: center; margin: 0.875rem 0; box-shadow: inset 0 2px 6px rgba(0,0,0,0.08); }
.total-box h2 { margin: 0; font-size: 1.25rem; font-weight: 900; }
.visitor-box { background: #f5f5f5; padding: 0.875rem; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
.info-box { background: #fff; padding: 0.75rem; border-radius: var(--radius-sm); margin-top: 0.5rem; font-size: 0.875rem; border: 1px solid #e5e5e5; }
.terms, .terms-box { background: #f9f9f9; padding: 0.75rem; border-radius: var(--radius-md); display: flex; align-items: center; gap: 0.625rem; margin: 0.75rem 0; box-shadow: var(--shadow-sm); }
.terms-box input, .terms input { width: 1.125rem; height: 1.125rem; cursor: pointer; }
.terms-box label, .terms label { font-size: 0.875rem; color: #333; cursor: pointer; }
.warning-box { background: #f9f9f9; color: var(--text-light); padding: 0.75rem; border-radius: var(--radius-md); font-size: 0.8125rem; margin: 0.625rem 0; box-shadow: var(--shadow-sm); border-left: 4px solid #e0e0e0; }
.back-btn { background: #ccc; color: #333; }
.confirm-btn { background: var(--green); color: #fff; }
@media (min-width: 481px) { .main-title { font-size: 1.375rem; } .total-box h2 { font-size: 1.375rem; } }
