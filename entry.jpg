@import url('../shared-base.css');
:root { --purple: #6a11cb; --blue: #2575fc; }
body { background: #f2f3f7; }
.success-top { text-align: center; margin: 0.875rem; }
.success-top h2 { color: #0a7f2e; margin-bottom: 0.3125rem; }
.success-top p { color: var(--text-light); }
.ticket-card { background: #fff; margin: 0.75rem auto; padding: 1.125rem; border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); max-width: 500px; }
.title { text-align: center; color: var(--purple); font-weight: 900; }
.subtitle { text-align: center; color: var(--text-light); margin-bottom: 0.625rem; }
.row { display: flex; justify-content: space-between; margin: 0.5rem 0; font-size: 0.9375rem; }
.total { text-align: center; color: var(--purple); font-weight: 900; font-size: 1.25rem; margin: 0.875rem 0; }
.home { background: #ccc; color: #333; }
.download { background: linear-gradient(135deg, var(--purple), var(--blue)); color: #fff; }
