@import url('../shared-base.css');
.main-title { text-align: center; font-size: 1rem; font-weight: 900; color: var(--green); }
.sub-title { text-align: center; font-size: 0.8125rem; color: var(--text-light); margin-bottom: 0.625rem; }
h3 { font-size: 1rem; color: var(--green); font-weight: 800; margin-bottom: 0.5rem; }
.boat-item { display: flex; justify-content: space-between; align-items: center; padding: 0.625rem; background: #fff; border-radius: var(--radius-sm); margin-bottom: 0.5rem; font-size: 0.875rem; }
.qty-box { display: flex; align-items: center; gap: 0.375rem; }
.qty-box button { width: 32px; height: 32px; border: none; border-radius: 50%; background: var(--green); color: #fff; font-size: 1rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.qty-box input { width: 2.75rem; text-align: center; border: none; border-radius: var(--radius-sm); background: #eee; padding: 0.375rem; font-size: 0.875rem; }
.total { margin-top: 0.625rem; padding: 0.75rem; text-align: center; font-size: 1.125rem; font-weight: 900; border-radius: var(--radius-xl); background: linear-gradient(135deg, var(--green), var(--green-dark)); color: #fff; }
label { display: block; margin-top: 0.625rem; font-weight: 700; color: var(--green); font-size: 0.875rem; }
input { width: 100%; padding: 0.75rem; margin-top: 0.25rem; border-radius: var(--radius-sm); border: 1px solid #ccc; background: #f7f7f7; font-size: 0.875rem; font-family: var(--font-body); }
input:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 2px rgba(63,95,63,0.15); }
small { display: block; font-size: 0.6875rem; color: #777; margin-top: 0.1875rem; }
.time { font-size: 0.75rem; color: var(--text-light); }
#summaryBox { font-size: 0.875rem; margin-bottom: 0.5rem; }
